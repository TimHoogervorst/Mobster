# Mobster Environment Variables
# Your GitHub Personal Access Token is entered via the web UI at /login
# (no need for AUTH_GITHUB_ID, AUTH_GITHUB_SECRET, or AUTH_SECRET in .env)

# Encryption key for tokens at rest (auto-generated on first run if not set)
# Generate: openssl rand -hex 32
# ENCRYPTION_KEY=

# Database path (optional, defaults to ./mobster.db)
# DATABASE_PATH=/data/mobster.db
